projects:
    pydantic:
        type: sitemap
        sources:
            - https://pydantic.dev/sitemap.xml
        crawl:
            parser: kreuzberg-dev # kreuzberg-dev | crawl4ai
            parse_type: markdown # crawl4ai: markdown | markdown-fit, kreuzberg-dev: markdown
            # Optional CSS selector applied before markdown conversion
            # content_selector: ".mw-parser-output"
        preprocessing:
            markdown:
                enabled: false

                ensure_h1: false                        # Adds missing # Tag
                remove_lines: false
                remove_blocks: false
                remove_sections: false
                remove_links: false
                remove_html_comments: false
                normalize_tables: false
                normalize_linebreak: false
                normalize_whitespace: false

    planes:
        type: pages
        sources:
            - https://de.wikipedia.org/wiki/Boeing_707
            - https://de.wikipedia.org/wiki/Boeing_717
            - https://de.wikipedia.org/wiki/Boeing_720
            - https://de.wikipedia.org/wiki/Boeing_727
            - https://de.wikipedia.org/wiki/Boeing_737
        crawl:
            parser: kreuzberg-dev # kreuzberg-dev | crawl4ai
            parse_type: markdown # crawl4ai: markdown | markdown-fit, kreuzberg-dev: markdown
            # Optional CSS selector applied before markdown conversion
            # content_selector: ".mw-parser-output"
        preprocessing:
            markdown:
                enabled: false

                ensure_h1: false
                remove_lines: false
                remove_blocks: false
                remove_sections: false
                remove_links: false
                remove_html_comments: false
                normalize_tables: false
                normalize_linebreak: false
                normalize_whitespace: false
