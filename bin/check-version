#!/usr/bin/env bash

set -euo pipefail

version_file="$(cat VERSION)"
version_pyproject="v$(grep '^version = ' pyproject.toml | sed -E 's/version = "([^"]+)"/\1/')"

if [ "$version_file" != "$version_pyproject" ]; then
  echo "Version mismatch:"
  echo "VERSION:        $version_file"
  echo "pyproject.toml: $version_pyproject"
  exit 1
fi

# v entfernen für Ausgabe
version_clean="${version_file#v}"

echo "Version OK: $version_clean"

